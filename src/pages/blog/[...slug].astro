---
import matter from "gray-matter";
import { marked } from "marked";
import BlogPostLayout from "@/layouts/BlogPostLayout.astro";
import LetsDiscuss from "@/components/blog/LetsDiscuss-1.astro";
import Testimonial from "@/components/blog/Testimonials.astro";

export function getStaticPaths() {
  const postFiles = import.meta.glob(
    "/hugo-blog/content/posts/*.md",
    {
      query: "?raw",
      import: "default",
      eager: true,
    }
  );

  return Object.keys(postFiles).map((filePath) => ({
    params: {
      slug: filePath.split("/").pop()?.replace(".md", ""),
    },
  }));
}

const postFiles = import.meta.glob(
  "/hugo-blog/content/posts/*.md",
  {
    query: "?raw",
    import: "default",
    eager: true,
  }
);

const slug = Astro.params.slug;

const filePath = Object.keys(postFiles).find(
  (p) => p.endsWith(`/${slug}.md`)
);

if (!filePath) {
  throw new Error(`Post not found: ${slug}`);
}

const rawMarkdown = postFiles[filePath] as string;

const { data, content } = matter(rawMarkdown);

const post = {
  title: data.title || "",
  subtitle: data.subtitle || "",
  date: data.date || "",
  author: data.author || "",
  image: data.image || "",
  content: marked(content),
};
---

<BlogPostLayout
  title={post.title}
  date={post.date}
  author={post.author}
  image={post.image}
  content={post.content}
  relatedPosts={[]}
  >
  <Testimonial/><LetsDiscuss /> </BlogPostLayout>