---
import MainLayout from "@/layouts/MainLayout.astro";
import disputeHero from "@/assets/Service1.png";
import martinaImg from "@/assets/martina-2.png";
import weightImg from "@/assets/Weight.png";
import serviceImg from "@/assets/redundancy.png";
---

<MainLayout title="Redundancy Legal Services">
    <main class="w-full min-h-screen bg-white">
        <!-- HERO SECTION -->
        <section class="w-full max-w-[1250px] mx-auto px-4 md:px-6 lg:px-8 pt-6 md:pt-8">
            <div
                class="relative
          
          mx-auto
          rounded-[30px]
          overflow-hidden
          min-h-[750px]
          flex
          flex-col
          justify-end
          items-start
          px-[32px]
          py-[50px]
          md:px-[50px]
          md:pb-[70px]"
            >
                <!-- BACKGROUND IMAGE -->
                <img
                    src={disputeHero.src}
                    alt="Redundancy Legal Services"
                    class="absolute inset-0 w-full h-full object-cover"
                />

                <!-- OVERLAY -->
               

                <!-- CONTENT -->
                <div
                    class="relative z-10 flex flex-col gap-[10px] max-w-[1100px]"
                >
                    <h1
                        class="font-['DM_Sans']
              font-normal
              text-white
              tracking-[-0.04em]
              leading-[100%]
              text-[50px]
              max-w-[275px]
              md:text-[80px]
              md:max-w-[620px]
              lg:max-w-[1100px]"
                    >
                        Expert Redundancy Lawyer in Ireland
                    </h1>

                    <h2
                        class="font-['Crimson_Text']
              font-normal
              text-white
              tracking-[-0.04em]
              text-[32px]
              leading-[110%]
              max-w-[275px]
              md:text-[40px]
              md:max-w-[620px]
              lg:max-w-[1100px]"
                    >
                        Dedicated Support for Employees
                    </h2>
                </div>
            </div>
        </section>

        <!-- INTRO SECTION -->
        <section class="w-full px-4 md:px-6 lg:px-8">
            <div
                class="max-w-[1200px]
          mx-auto
          flex
          flex-col
          justify-center
          items-center
          px-[32px]
          py-[40px]
          gap-[40px]
          md:px-[50px]
          md:pt-[60px]
          md:pb-[0px]
          lg:pb-[80px]"
            >
                <p
                    class="font-['DM_Sans']
            font-normal
            text-[#6F6F6F]
            tracking-[-0.005em]
            leading-[140%]
            text-[21px]
            
            md:max-w-[620px]
            lg:max-w-[1100px]"
                >
                    Losing your job due to redundancy is a highly stressful and
                    overwhelming experience. You likely have immediate concerns
                    about your financial security, your legal rights, and
                    whether your employer is treating you fairly. We provide
                    employees with clear, practical, and compassionate
                    redundancy legal advice. We are here to cut through the
                    legal jargon, review your options, and ensure you receive
                    every cent and protection you are entitled to under the law.
                    If you have been placed at risk of redundancy, do not sign
                    anything until you have spoken with an experienced
                    redundancy lawyer.
                </p>

                <button
                    class="bg-[#0B838E]
            text-white
            rounded-full
            shadow-md
            px-[22px]
            py-[14px]
            font-['DM_Sans']
            font-bold
            text-[14px]
            leading-[140%]
            tracking-[-0.025em]"
                >
                    Contact Us
                </button>
            </div>
        </section>

        <!-- SERVICES BENTO SECTION -->
        <section class="w-full px-4 md:px-6 lg:px-8">
            <div
                class="max-w-[1200px]
          mx-auto
          bg-white
          flex
          flex-col
          justify-center
          items-center
          px-[20px]
          py-[0px]
          gap-[50px]
          md:px-[40px]
          md:py-[60px]
          lg:py-[0px]"
            >
                <!-- HEADER -->
                <div
                    class="flex
            flex-col
            items-center
            gap-[10px]
            w-full
            max-w-[1017px]"
                >
                    <h2
                        class="font-['Crimson_Text']
              font-normal
              text-black
              text-center
              tracking-[-0.03em]
              leading-[95%]
              text-[50px]
              md:text-[54px]
              lg:text-[60px]"
                    >
                        Our Redundancy Legal Services for Employees
                    </h2>

                    <p
                        class="font-['DM_Sans']
              font-normal
              text-[#5D5D5D]
              text-center
              tracking-[-0.005em]
              leading-[140%]
              text-[21px]
              max-w-[335px]
              md:max-w-[620px]
              lg:max-w-[732px]"
                    >
                        We offer comprehensive support for employees navigating
                        the redundancy process, from initial consultations to
                        formal disputes. A dedicated solicitor for redundancy
                        can assist you with:
                    </p>
                </div>

                <!-- BENTO GRID -->
                <div
                    class="w-full
            flex
            flex-col
            gap-[30px]"
                >
                    <!-- ROW 1 -->
                    <div
                        class="flex
              flex-col
              md:flex-row
              gap-[30px]"
                    >
                        <!-- CARD 1 -->
                        <div
                            class="flex-1
                bg-[#0B838E]
                rounded-[10px]
                px-[20px]
                py-[30px]
                flex
                flex-col
                items-center
                justify-center
                text-center"
                        >
                            <div class="flex flex-col items-center gap-[20px]">
                                <h3
                                    class="font-['DM_Sans']
                    font-medium
                    text-white
                    tracking-[-0.03em]
                    leading-[100%]
                    text-[12px]
                    md:text-[16px]
                    lg:text-[36px]"
                                >
                                    Severance & Compromise Agreements
                                </h3>

                                <p
                                    class="font-['DM_Sans']
                    font-normal
                    text-white
                    text-center
                    tracking-[-0.01em]
                    leading-[140%]
                    text-[10.5px]
                    md:text-[11px]
                    lg:text-[18px]"
                                >
                                    Employers often offer enhanced severance
                                    packages (ex gratia payments) in exchange
                                    for signing away your right to sue. We
                                    review these legally binding agreements to
                                    ensure the terms are fair, tax-efficient,
                                    and in your best interest before you sign.
                                </p>
                            </div>
                        </div>

                        <!-- CARD 2 -->
                        <div
                            class="flex-1
                bg-[#0B838E]
                rounded-[10px]
                px-[20px]
                py-[30px]
                flex
                flex-col
                items-center
                justify-center
                text-center"
                        >
                            <div class="flex flex-col items-center gap-[20px]">
                                <h3
                                    class="font-['DM_Sans']
                    font-medium
                    text-white
                    tracking-[-0.03em]
                    leading-[100%]
                    text-[12px]
                    md:text-[16px]
                    lg:text-[36px]"
                                >
                                    Calculating Redundancy Payments
                                </h3>

                                <p
                                    class="font-['DM_Sans']
                    font-normal
                    text-white
                    text-center
                    tracking-[-0.01em]
                    leading-[140%]
                    text-[10.5px]
                    md:text-[11px]
                    lg:text-[18px]"
                                >
                                    We verify that your employer is correctly
                                    calculating redundancy figures based on your
                                    continuous service and normal weekly pay,
                                    ensuring you receive your full statutory
                                    entitlement.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- ROW 2 -->
                    <div
                        class="flex
              flex-col
              md:flex-row
              gap-[30px]"
                    >
                        <!-- CARD 3 -->
                        <div
                            class="flex-1
                bg-[#0B838E]
                rounded-[10px]
                px-[30px]
                py-[26px]
                flex
                flex-col
                items-center
                justify-center
                text-center"
                        >
                            <div class="flex flex-col items-center gap-[20px]">
                                <h3
                                    class="font-['DM_Sans']
                    font-medium
                    text-white
                    tracking-[-0.03em]
                    leading-[100%]
                    text-[12px]
                    md:text-[16px]
                    lg:text-[36px]"
                                >
                                    Challenging Unfair Selection
                                </h3>

                                <p
                                    class="font-['DM_Sans']
                    font-normal
                    text-white
                    text-center
                    tracking-[-0.01em]
                    leading-[140%]
                    text-[10.5px]
                    md:text-[11px]
                    lg:text-[18px]"
                                >
                                    Irish redundancy law dictates that
                                    redundancy must be genuine—meaning the role
                                    is no longer needed, not the person. If you
                                    were unfairly targeted due to age,
                                    pregnancy, or personal differences, or if
                                    you were replaced by someone doing the same
                                    job, we can help you bring a claim for
                                    unfair dismissal to the Workplace Relations
                                    Commission (WRC).
                                </p>
                            </div>
                        </div>

                        <!-- CARD 4 -->
                        <div
                            class="flex-1
                bg-[#0B838E]
                rounded-[10px]
                px-[20px]
                py-[30px]
                flex
                flex-col
                items-center
                justify-center
                text-center"
                        >
                            <div class="flex flex-col items-center gap-[20px]">
                                <h3
                                    class="font-['DM_Sans']
                    font-medium
                    text-white
                    tracking-[-0.03em]
                    leading-[100%]
                    text-[12px]
                    md:text-[16px]
                    lg:text-[36px]"
                                >
                                    TUPE Ireland Redundancy
                                </h3>

                                <p
                                    class="font-['DM_Sans']
                    font-normal
                    text-white
                    text-center
                    tracking-[-0.01em]
                    leading-[140%]
                    text-[10.5px]
                    md:text-[11px]
                    lg:text-[18px]"
                                >
                                    If your company was recently sold or taken
                                    over, your employment rights are protected.
                                    We advise employees who are facing unfair
                                    restructuring or job losses following a
                                    business transfer.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- TEXT + IMAGE SECTION -->
        <section class="w-full max-w-[1250px] mx-auto px-4 md:px-6 lg:px-8">
            <div
                class="
          mx-auto
          flex
          flex-col
          lg:flex-row
          items-start
          gap-[50px]
          lg:gap-[20px]
          py-[50px]
          md:py-[60px]
          lg:py-[80px]"
            >
                <!-- IMAGE -->
                <div
                    class="reveal w-full
            lg:w-[590px]
            h-[385px]
            md:h-[744px]
            lg:h-[711px]
            rounded-[30px]
            overflow-hidden
            shrink-0"
                >
                    <img
                        src={martinaImg.src}
                        alt="Martina Murphy"
                        class="w-full h-full object-cover"
                    />
                </div>

                <!-- TEXT -->
                <div
                    class="w-full
            flex
            flex-col
            items-start
            lg:pt-[20px]
            lg:pb-[80px]
            lg:pl-[60px]"
                >
                    <div
                        class="flex
              flex-col
              gap-[40px]
              max-w-[530px]"
                    >
                        <h2
                            class="font-['Crimson_Text']
                font-normal
                text-black
                tracking-[-0.03em]
                leading-[95%]
                text-[50px]
                md:text-[54px]
                lg:text-[60px]"
                        >
                            Are You Getting What You Deserve?
                        </h2>

                        <p
                            class="font-['DM_Sans']
                font-normal
                text-[#6F6F6F]
                tracking-[-0.005em]
                leading-[140%]
                text-[21px]"
                        >
                            When a role is made genuinely redundant, eligible
                            employees (with at least two years of continuous
                            service) are legally entitled to a tax-free
                            redundancy payment. Under statutory redundancy
                            Ireland rules, you are entitled to: Two weeks’ pay
                            for every year of service. Plus one additional
                            "bonus" week.

                            <br /><br />

                            (Note: The statutory calculation is currently capped
                            at a maximum of €600 per week).

                            <br /><br />

                            Don't leave money on the table. Many employers offer
                            enhanced packages above the statutory minimum.
                            Having a legal professional negotiate or review your
                            package ensures your financial security is maximized
                            as you transition to your next role.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- TESTIMONIAL SECTION -->
        <section class="w-full max-w-[1250px] mx-auto px-4 md:px-6 lg:px-8">
            <div
                class="
          mx-auto
          flex
          flex-col-reverse
          lg:flex-row
          items-start
          gap-10
          lg:gap-5"
            >
                <!-- QUOTE -->
                <div
                    class="w-full
            lg:flex-1
            flex
            flex-col
            justify-center
            items-start
            lg:pl-[50px]
            gap-[50px]
            lg:min-h-[633px]"
                >
                    <h2
                        class="font-['Crimson_Text']
              font-normal
              text-[32px]
              leading-[110%]
              tracking-[-0.04em]
              text-black
              md:text-[40px]
              md:leading-[110%]
              lg:text-[40px]
              lg:leading-[105%]
              max-w-[500px]"
                    >
                        "Martina Murphy Solicitors handled my estate planning
                        with such care and professionalism. They listened to my
                        concerns and made the process clear and straightforward.
                        I now have complete peace of mind knowing my family's
                        future is secure."
                    </h2>

                    <!-- NAME -->
                    <div
                        class="flex
              flex-row
              items-center
              gap-2"
                    >
                        <p
                            class="font-['DM_Sans']
                font-normal
                text-[21px]
                leading-[140%]
                tracking-[-0.005em]
                text-black"
                        >
                            Dave Luca
                        </p>

                        <span
                            class="font-['DM_Sans']
                font-normal
                text-[10.5px]
                md:text-[11px]
                lg:text-[12px]
                leading-[140%]
                tracking-[-0.01em]
                text-[#8E9C78]"
                        >
                            Business Owner
                        </span>
                    </div>
                </div>

                <!-- IMAGE -->
                <div
                    class=" reveal w-full
            lg:w-[558px]
            h-[343px]
            md:h-[720px]
            lg:h-[633px]
            rounded-[30px]
            overflow-hidden
            shrink-0"
                >
                    <img
                        src={weightImg.src}
                        alt="Testimonial"
                        class="w-full h-full object-cover"
                    />
                </div>
            </div>
        </section>

        <section
            class="w-full  mx-auto
        flex flex-col items-center
        py-[40px] sm:py-[80px]
        gap-[10px]"
        >
            <div
                class="w-full max-w-[911px]
          flex flex-col items-center
          gap-[10px]"
            >
                <h2
                    class="font-crimson font-normal
            text-[#0B838E]
            text-center
            tracking-[-0.03em]
            leading-[95%]
            text-[50px]
            sm:text-[54px]
            lg:text-[60px]"
                >
                    Why Choose Martina Murphy Solicitors?
                </h2>
            </div>
        </section>
        <section
            class="w-full max-w-[1200px] mx-auto
        flex flex-col lg:flex-row
        items-start
        px-[15px]
        pb-[50px]
        gap-[20px]"
        >
            <!-- STAT 1 -->
            <div
                class="reveal w-full lg:flex-1
          flex flex-col
          items-start
          gap-[40px]
          py-[16px]
          pr-[16px]
          border-b lg:border-b-0
          lg:border-r border-black"
            >
                <h3
                    class="font-crimson font-normal
            text-[#0B838E]
            text-[60px]
            sm:text-[84px]
            lg:text-[120px]
            leading-[95%]
            tracking-[-0.03em]"
                >
                    100+
                </h3>

                <p
                    class="font-dm font-normal
            text-black
            text-[21px]
            leading-[140%]
            tracking-[-0.005em]"
                >
                    years of combined experience. Our partners have successfully
                    negotiated and resolved complex disputes across all areas of
                    Irish law.
                </p>
            </div>

            <!-- STAT 2 -->
            <div
                class="reveal w-full lg:flex-1
          flex flex-col
          items-start
          gap-[40px]
          py-[16px]
          pr-[16px]
          border-b lg:border-b-0
          lg:border-r border-black"
            >
                <h3
                    class="font-crimson font-normal
            text-[#0B838E]
            text-[60px]
            sm:text-[84px]
            lg:text-[120px]
            leading-[95%]
            tracking-[-0.03em]"
                >
                    LQ
                </h3>

                <p
                    class="font-dm font-normal
            text-black
            text-[21px]
            leading-[140%]
            tracking-[-0.005em]"
                >
                    We are proud to hold the LQ Standard of Excellence — an
                    independent verification that we treat every single client
                    with respect, transparency, and genuine care.
                </p>
            </div>

            <!-- STAT 3 -->
            <div
                class="reveal w-full lg:flex-1
          flex flex-col
          items-start
          gap-[40px]
          py-[16px]"
            >
                <h3
                    class="font-crimson font-normal
            text-[#0B838E]
            text-[60px]
            sm:text-[84px]
            lg:text-[120px]
            leading-[95%]
            tracking-[-0.03em]"
                >
                    200+
                </h3>

                <p
                    class="font-dm font-normal
            text-black
            text-[21px]
            leading-[140%]
            tracking-[-0.005em]"
                >
                    different clients have sought our expertise. We will give
                    you a candid, realistic assessment of your case from day
                    one.
                </p>
            </div>
        </section>

        <section
           class="w-full max-w-[1250px] mx-auto px-4 sm:px-6 lg:px-8"
        >
            <!-- DIVIDER -->
            <div class="w-full border-t border-black"></div>

            <!-- CONTENT -->
            <div
                class="w-full
          flex flex-col lg:flex-row
          items-start
          gap-[40px] lg:gap-[0px]"
            >
                <!-- LEFT TITLE -->
                <div class="w-full lg:w-1/2">
                    <h2
                        class="font-crimson font-normal text-black
              text-[50px] sm:text-[54px] lg:text-[60px]
              leading-[95%] lg:leading-[90%]
              tracking-[-0.03em]"
                    >
                        Our Services
                    </h2>
                </div>

                <!-- RIGHT SERVICES -->
                <div
                    class="reveal w-full lg:w-1/2
            flex flex-col
            gap-[40px]"
                >
                    <div
                        class="grid grid-cols-1 sm:grid-cols-2
              gap-y-[40px] gap-x-[20px]"
                    >
                        <div class="flex flex-col gap-[20px] pr-[20px]">
                            <h3
                                class="font-dm font-normal
                  text-[21px]
                  leading-[140%]
                  tracking-[-0.005em]
                  text-[#767676]"
                            >
                                BUYING & SELLING
                            </h3>

                            <p
                                class="font-dm font-normal
                  text-black
                  text-[18px] sm:text-[21px]
                  leading-[135%] sm:leading-[140%]
                  tracking-[-0.02em] sm:tracking-[-0.005em]"
                            >
                                Conveyancing is the legal process of
                                transferring property. This could be buying or
                                selling a house or commercial unit.
                            </p>
                        </div>

                        <div class="flex flex-col gap-[20px] pr-[20px]">
                            <h3
                                class="font-dm font-normal
                  text-[21px]
                  leading-[140%]
                  tracking-[-0.005em]
                  text-[#767676]"
                            >
                                EMPLOYMENT LAW
                            </h3>

                            <p
                                class="font-dm font-normal
                  text-black
                  text-[18px] sm:text-[21px]
                  leading-[135%] sm:leading-[140%]
                  tracking-[-0.02em] sm:tracking-[-0.005em]"
                            >
                                We advise both employees and employers on
                                workplace disputes, contracts, dismissals,
                                grievances, and mediation services.
                            </p>
                        </div>

                        <div class="flex flex-col gap-[20px] pr-[20px]">
                            <h3
                                class="font-dm font-normal
                  text-[21px]
                  leading-[140%]
                  tracking-[-0.005em]
                  text-[#767676]"
                            >
                                FAMILY & PROBATE
                            </h3>

                            <p
                                class="font-dm font-normal
                  text-black
                  text-[18px] sm:text-[21px]
                  leading-[135%] sm:leading-[140%]
                  tracking-[-0.02em] sm:tracking-[-0.005em]"
                            >
                                Sensitive legal support for wills, estates,
                                probate matters, contested inheritances, and
                                family dispute resolution.
                            </p>
                        </div>

                        <div class="flex flex-col gap-[20px] pr-[20px]">
                            <h3
                                class="font-dm font-normal
                  text-[21px]
                  leading-[140%]
                  tracking-[-0.005em]
                  text-[#767676]"
                            >
                                CIVIL LITIGATION
                            </h3>

                            <p
                                class="font-dm font-normal
                  text-black
                  text-[18px] sm:text-[21px]
                  leading-[135%] sm:leading-[140%]
                  tracking-[-0.02em] sm:tracking-[-0.005em]"
                            >
                                Strategic representation for commercial
                                disputes, contract breaches, debt recovery, and
                                complex civil litigation cases.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-center gap-[3px]">
                        <a
                            href="#"
                            class="font-dm font-normal
                text-[21px]
                leading-[140%]
                tracking-[-0.005em]
                text-[#767676]
                hover:text-black
                transition-colors duration-300"
                        >
                            See All Services
                        </a>

                        <span
                            class="font-['Instrument_Sans']
                font-medium
                text-[16px]
                leading-[110%]
                tracking-[-0.03em]
                text-[#767676]"
                        >
                            →
                        </span>
                    </div>
                </div>
            </div>

            <!-- LARGE IMAGE -->
            <div
                class="relative
          w-full
          h-[694px]
          rounded-[30px]
          overflow-hidden"
            >
                <img
                    src={serviceImg.src}
                    alt="Our Services"
                    class="w-full h-full object-cover"
                />

                <div class="absolute inset-0 bg-black/20"></div>
            </div>
        </section>
        <!-- CTA Section -->
<section
  class="w-full max-w-[1250px] mx-auto px-4 sm:px-6 lg:px-8 mt-15 mb-15"
>
  <div
    class="w-full max-w-[720px] mx-auto
           flex flex-col items-center
           gap-10
           max-md:gap-[30px]"
  >
    <!-- Heading -->
    <h2
      class="font-['Crimson_Text'] font-normal
             text-[60px] leading-[90%]
             tracking-[-0.03em]
             text-black text-center
             
             md:text-[54px]

             max-md:text-[50px]
             max-md:leading-[95%]"
    >
      Protect Your Rights Today
    </h2>

    <!-- Paragraph -->
    <p
      class="font-['DM_Sans'] font-normal
             text-[21px] leading-[140%]
             tracking-[-0.005em]
             text-[#6F6F6F]
             text-center
             w-full

             max-md:text-[21px]"
    >
      You have a strict timeframe to challenge a redundancy or claim
      unfair dismissal. Don't wait to get the answers you need. Contact
      our office today to schedule a confidential consultation with a
      specialist employment solicitor.
    </p>

    <!-- Button -->
    <a
      href="/contact"
      class="flex items-center justify-center
             px-[22px] py-[14px]
             w-[260px] h-12
             bg-[#0B838E]
             rounded-full
             shadow-[0px_4px_4px_rgba(0,0,0,0.25)]
             transition-all duration-300
             hover:scale-105 hover:bg-[#096d76]"
    >
      <span
