    items-start
    gap-6 lg:gap-[40px]
    py-4"
    >
      <h3
        class="font-['Crimson_Text'] font-normal
      text-[#0B838E]
      text-[48px]
      sm:text-[70px]
      lg:text-[120px]
      leading-[95%]
      tracking-[-0.03em]"
      >
        200+
      </h3>

      <p
        class="font-dm font-normal
      text-black
      text-[16px]
      sm:text-[18px]
      lg:text-[21px]
      leading-[150%]
      tracking-[-0.005em]"
