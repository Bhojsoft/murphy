---
import MainLayout from "@/layouts/MainLayout.astro";
import disputeHero from "@/assets/Service1.png";
import martinaImg from "@/assets/martina-2.png";
import antoinetteImg from "@/assets/team/Antoinette-Cusack.jpg";
import caroline from "@/assets/team/Caroline Kennely.jpg";
import Lynda from "@/assets/team/Lynda-Ivess.jpg";
import shirley from "@/assets/team/Shirley-Cossavella.jpg";
import yvonne from "@/assets/team/Yvonne-Nolan.jpg";
import a from "@/assets/team/MartinaMurphySolicitors-179.jpg";
import b from "@/assets/team/MartinaMurphySolicitors-284.jpg";
import c from "@/assets/team/MartinaMurphySolicitors-467.jpg";
import weightImg from "@/assets/Weight.png";
import redundancyImg from "@/assets/redundancy.png";
import hero from "@/assets/abouthero.jpeg";
---

<MainLayout>
  <!-- HEADER SECTION -->
  <section
    class="w-full max-w-[1250px] mx-auto px-4 md:px-8 lg:px-0 pt-16 md:pt-30"
  >
    <div
      class="w-full
      md:w-[95%]
      mx-auto
      h-[420px]
      md:h-[600px]
      lg:h-[750px]
      rounded-[30px]
      overflow-hidden
      flex
      flex-col
      justify-end
      items-start
      px-6
      md:px-[50px]
      py-10
      md:py-[70px]
      gap-3
      md:gap-[10px]
      bg-cover
      bg-center
      relative"
      style={`background-image: url(${hero.src})`}
    >
      <div class="absolute inset-0 bg-black/40"></div>
      <!-- ABOUT US -->
      <h1
        class="reveal
        w-full
        font-dm
        font-normal
        text-white
        tracking-[-0.04em]
        text-[34px]
        sm:text-[48px]
        md:text-[80px]
        leading-[100%]
        brightness-125"
      >
        About us
      </h1>

      <!-- SUBTITLE -->
      <h2
        class="reveal
        w-full
        font-['Crimson_Text']
        font-normal
        text-white
        tracking-[-0.04em]
        text-[18px]
        sm:text-[26px]
        md:text-[40px]
        leading-[110%]
        md:leading-[105%]
        brightness-125"
      >
        Legal services with a personal touch
      </h2>
    </div>
  </section>

  <section
    class="w-full max-w-[1250px] mx-auto
  flex flex-col lg:flex-row
  items-start
  px-4 sm:px-6 lg:px-0
  pb-12 lg:pb-[50px]
  pt-14 lg:pt-30
  gap-10 lg:gap-[20px]"
  >
    <!-- STAT 1 -->
    <div
      class="w-full lg:flex-1
    flex flex-col
    items-start
    gap-6 lg:gap-[40px]
    py-4
    pr-0 lg:pr-[16px]
    border-b lg:border-b-0
    lg:border-r border-black"
    >
      <h3
        class="font-[Crimson_Text] font-normal
      text-[#0B838E]
      text-[48px]
      sm:text-[70px]
      lg:text-[120px]
      leading-[95%]
      tracking-[-0.03em]"
      >
        100+
      </h3>

      <p
        class="font-dm font-normal
      text-black
      text-[16px]
      sm:text-[18px]
      lg:text-[21px]
      leading-[150%]
      tracking-[-0.005em]"
      >
        years of combined experience. Our partners have successfully negotiated
        and resolved complex disputes across all areas of Irish law.
      </p>
    </div>

    <!-- STAT 2 -->
    <div
      class="w-full lg:flex-1
    flex flex-col
    items-start
    gap-6 lg:gap-[40px]
    py-4
    pr-0 lg:pr-[16px]
    border-b lg:border-b-0
    lg:border-r border-black"
    >
      <h3
        class="font-[Crimson_Text] font-normal
      text-[#0B838E]
      text-[48px]
      sm:text-[70px]
      lg:text-[120px]
      leading-[95%]
      tracking-[-0.03em]"
      >
        LQ
      </h3>

      <p
        class="font-dm font-normal
      text-black
      text-[16px]
      sm:text-[18px]
      lg:text-[21px]
      leading-[150%]
      tracking-[-0.005em]"
      >
        We are proud to hold the LQ Standard of Excellence — an independent
        verification that we treat every single client with respect,
        transparency, and genuine care.
      </p>
    </div>

    <!-- STAT 3 -->
    <div
      class="w-full lg:flex-1
