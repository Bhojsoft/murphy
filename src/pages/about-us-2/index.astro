  >
    <div class="w-full flex flex-col gap-10 lg:gap-[30px]">
      <!-- Divider -->
      <div class="w-full border-t border-black"></div>

      <!-- Content -->
      <div class="flex flex-col lg:flex-row items-start gap-10 lg:gap-0">
        <!-- Heading -->
        <div class="w-full lg:w-1/2">
          <h2
            class="font-[Crimson_Text] font-normal
          text-[34px] sm:text-[44px] lg:text-[60px]
          leading-[95%] lg:leading-[90%]
          tracking-[-0.03em] text-black"
