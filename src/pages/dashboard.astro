---
import MainLayout from "@/layouts/MainLayout.astro";

const blogs = [
  ["Accidents at Work", "/personal-injury/accidents-at-work/"],
  ["Buying a Property", "/conveyancing/buying-a-house/"],
  ["Car Injury Solicitors", "/personal-injury/car-injury/"],
  ["Child Custody Solicitors", "/family-law/child-custody/"],
  ["Commissioner for Oaths", "/commissioner-for-oaths/"],
  ["Conveyancing", "/conveyancing/"],
  ["Divorce and Assets", "/divorce-and-assets/"],
  ["Drafting Wills", "/drafting-wills/"],
  ["Elder Law Solicitors", "/elder-law/"],
  ["Enduring Power of Attorney", "/power-of-attorney/enduring/"],
  ["Estate Planning", "/estate-planning/"],
  ["Expert Divorce Solicitors", "/divorce-and-assets/solicitors/"],
  ["Fair Deal Scheme Solicitors", "/elder-law/fair-deal-scheme/"],
  ["Family Home Property Divorce", "/divorce-and-assets/family-home-property/"],
  ["Family Law Solicitors", "/family-law/"],
  ["Financial Power of Attorney", "/power-of-attorney/financial/"],
  ["General Power of Attorney Solicitors", "/power-of-attorney/general/"],
  ["House Purchase Solicitor Fees", "/conveyancing/fees/"],
  ["Inheritance and Succession Solicitors", "/inheritance-solicitors/"],
  ["Judicial Separation Solicitors", "/divorce-and-assets/judicial-separation/"],
  ["Legal Guardianship", "/family-law/guardianship/"],
  ["Medical Power of Attorney Solicitors", "/power-of-attorney/medical-healthcare/"],
  ["Personal Injury at Work Solicitors", "/employment-law/employees/injury-at-work/"],
  ["Personal Injury Solicitors", "/personal-injury/"],
  ["Power of Attorney Solicitors", "/power-of-attorney/"],
  ["Probate Disputes Solicitors", "/probate-dispute/"],
  ["Road Traffic Accidents Solicitors", "/personal-injury/road-traffic/"],
  ["Selling a Property Solicitors", "/conveyancing/selling-a-house/"],
  ["Wills and Probate", "/wills-and-probate/"],
  ["Blog Archive", "/blog/"]
];
---

<MainLayout>
  <section class="bg-[#0B838E] min-h-screen py-24  mb-25">
    <div class="max-w-7xl mx-auto px-6 ">

      <h1 class="text-center text-white text-[80px] md:text-[120px] lg:text-[120px] font-bold leading-none mb-8">
  Our Blogs
</h1>

<p class="text-center text-white/80 max-w-2xl mx-auto mb-20 text-lg">
  Explore legal insights, guides, and practical advice from our experienced solicitors.
</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        {blogs.map(([title, href]) => (
          <a
            href={href}
            class="
              bg-white
              p-8
              rounded-lg
              shadow-sm
              hover:shadow-xl
              transition-all
              duration-300
              hover:-translate-y-1
              block
            "
          >
            <h2 class="text-2xl font-bold text-gray-900 mb-4">
              {title}
            </h2>

            <p class="text-gray-600 mb-6">
              Read our detailed guide and legal insights on {title.toLowerCase()}.
            </p>

            <span class="text-[#0B838E] font-semibold">
              Read More →
            </span>
          </a>
        ))}

      </div>

    </div>
  </section>
</MainLayout>