---
interface BlogPost {
  title: string;
  description: string;
}

const {
  posts = [],
} = Astro.props as {
  posts?: BlogPost[];
};
---

<section class="w-full max-w-[1200px] mx-auto py-20">
  <h2 class="text-[60px] mb-10">Blog Posts</h2>

  {posts.map((post) => (
    <div class="mb-8">
      <h3>{post.title}</h3>
      <p>{post.description}</p>
    </div>
  ))}
</section>