---
const {
  title = "Let's Discuss Your Project",
  description = "Have a question or an idea you'd like to explore? Get in touch with our team and let's talk about how we can help."
} = Astro.props;
---

<section class="py-16">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center bg-gray-50 rounded-3xl p-10">
      <h2 class="text-3xl font-bold mb-4">
        {title}
      </h2>

      <p class="text-gray-600 mb-8">
        {description}
      </p>

      <a
        href="/contact"
        class="
          inline-flex
          items-center
          justify-center
          bg-[#0B838E]
          text-white
          rounded-full
          px-[22px]
          py-[14px]
          text-[14px]
          font-bold
          tracking-[-0.025em]
          hover:bg-[#086c74]
          transition-all
          duration-300
        "
      >
        Let's Talk
      </a>
    </div>
  </div>
</section>