---
import Logo from "../../assets/MM_logo.png";
---

<footer
  class="bg-[#F7F4EB]
    mx-[20px]
    md:mx-[60px]
    lg:mx-[100px]
    xl:mx-[152px]"
>
  <div
    class="max-w-[1280px]
      mx-auto
      px-7
      md:px-[50px]
      xl:px-[152px]
      py-[68px]
      flex
      flex-col
      gap-12
      md:gap-[84px]"
  >
    <!-- Footer Header -->
    <div
      class="flex
        flex-col
        md:flex-row
        items-center
        md:items-center
        justify-between
        gap-6
        w-full"
    >
      <!-- Logo -->
      <div class="flex items-center justify-center">
        <img
          src={Logo.src}
          alt="MM Logo"
          class="w-[119px]
            h-[121px]
            object-contain
            md:w-[50px]
            md:h-[51px]
            xl:w-[119px]
            xl:h-[121px]"
        />
      </div>

      <!-- Brand Name -->
      <h2
        class="text-center
          md:text-right
          font-[Geist]
          text-black
          text-[20px]
          md:text-[26px]
          xl:text-[34px]
          leading-[120%]"
      >
        Martina Murphy Solicitors
      </h2>
    </div>

    <!-- Footer Subhead -->
    <div class="w-full">
      <p
        class="text-black
          text-center
          font-[Geist]
          text-[18px]
          leading-[135%]
          tracking-[-0.02em]"
      >
        Deep expertise, decisive courtroom presence
      </p>
    </div>

    <!-- Footer Contact Information -->
    <div
      class="flex
        flex-col
        md:flex-row
        gap-8
        md:gap-6
        xl:gap-[45px]"
    >
      <!-- Column 1 -->
      <div class="flex flex-col gap-[2px] w-full md:w-[255px]">
        <a
          href="mailto:info@martinamurphy.ie"
          class="text-black
            underline
            font-[Geist]
            text-[14px]
            leading-[140%]
            hover:opacity-70
            transition"
        >
          info@martinamurphy.ie
        </a>

        <a
          href="tel:+35361303311"
          class="text-black
            font-[Geist]
            text-[14px]
            leading-[140%]
            hover:opacity-70
            transition"
        >
          (061) 303311
        </a>
      </div>

      <!-- Column 2 -->
      <div class="w-full md:w-[255px]">
        <p
          class="text-black
            font-[Geist]
            text-[14px]
            leading-[140%]"
        >
          Unit 7 Crescent Court,
          <br />
          St Nessans Road,
          <br />
          Dooradoyle, Limerick
        </p>
      </div>

      <!-- Column 3 -->
      <div class="flex flex-col gap-[2px] w-full md:flex-1">
        <a
          href="https://www.instagram.com/martinamurphysolicitors/"
          class="text-black
            font-[Geist]
            text-[14px]
            leading-[140%]
            hover:opacity-70
            transition"
        >
          Instagram
        </a>

        <a
          href="https://www.facebook.com/MartinaMurphySolicitorsLimerick"
          class="text-black
            font-[Geist]
            text-[14px]
            leading-[140%]
            hover:opacity-70
            transition"
        >
          Facebook
        </a>

        <a
          href="https://www.linkedin.com/company/martina-murphy-solicitors-limerick/"
          class="text-black
            font-[Geist]
            text-[14px]
            leading-[140%]
            hover:opacity-70
            transition"
        >
          LinkedIn
        </a>

        <a
          href="https://twitter.com/martinamurphyie?lang=en"
          class="text-black
            font-[Geist]
            text-[14px]
            leading-[140%]
            hover:opacity-70
            transition"
        >
          Twitter
        </a>
      </div>

      <div class="flex flex-col gap-[2px] w-full md:flex-1">
        <a
          href="/dispute-2"
          class="text-black
            font-[Geist]
            text-[14px]
            leading-[140%]
            hover:opacity-70
            transition"
        >
          Dispute
        </a>

        <a
          href="/redundancy-2"
          class="text-black
            font-[Geist]
            text-[14px]
            leading-[140%]
            hover:opacity-70
            transition"
        >
          Redundancy
        </a>
      </div>
    </div>

    <!-- Footer Copyright -->
    <div>
      <p
        class="text-black
          font-[Geist]
          text-[14px]
          leading-[140%]"
      >
        Jones & Brown Legal © 2025 All Rights Reserved
      </p>
    </div>
  </div>
</footer>
