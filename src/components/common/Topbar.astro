---

<header class="top-0 left-0 w-full z-50">
  <div class="flex justify-between items-center px-6 py-4">
    <button
  id="menuBtn"
  type="button"
  class="text-3xl cursor-pointer"
>
  ☰
</button>

    <a
      href="/contact"
      class="hidden md:inline-block bg-[rgb(11,131,142)] text-white px-6 py-3 rounded-full"
    >
      Contact Us ↗
    </a>
  </div>
</header>

<div id="overlay" class="fixed inset-0 bg-black/40 hidden z-[999]">
  <div
    class="absolute left-0 top-0 h-full w-[320px] bg-white p-6 overflow-y-auto"
  >
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-xl font-semibold">Menu</h3>

      <button id="closeBtn" class="text-2xl"> ✕ </button>
    </div>

    <div class="flex flex-col">
  {
    menuLinks.map((link, index) =>
      link.children ? (
        <div class="border-b border-gray-200">
          <div
  class="accordion-btn w-full flex items-center justify-between py-3"
  data-index={index}
>
  <a
    href={link.href}
    class="flex-1 text-left hover:text-[rgb(11,131,142)]"
  >
    {link.name}
  </a>

  <button
    type="button"
    class="accordion-toggle px-2"
  >
    <span class="accordion-icon">+</span>
  </button>
</div>

          <div class="accordion-content hidden pb-3">
           
            {link.children.map((child) => (
              <a
                href={child.href}
                class="block pl-8 py-2 text-gray-600 hover:text-[rgb(11,131,142)]"
              >
                {child.name}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a
          href={link.href}
          class="border-b border-gray-200 py-3 hover:text-[rgb(11,131,142)]"
        >
          {link.name}
        </a>
      )
    )
  }
</div>
  </div>
</div>

