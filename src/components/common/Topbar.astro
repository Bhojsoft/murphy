---
const menuLinks = [
  { name: "Home", href: "/" },
  { name: "About Us", href: "/about-us-2" },
  { name: "Wills and Probate", href: "/wills-and-probate/" },
  { name: "Family Law", href: "/family-law/" },
  { name: "Divorce & Assets", href: "/divorce-and-assets/" },
  { name: "Power of Attorney", href: "/power-of-attorney/" },
  { name: "Personal Injury & Accidents", href: "/personal-injury/" },
  { name: "Conveyancing", href: "/conveyancing/" },
  { name: "Employment Law (Employees)", href: "/employment-law/employees/redundancies/" },
  { name: "Employment Law (Employers)", href: "/employment-law/employers/dispute-resolution/" },
  { name: "Elder Law", href: "/elder-law/" },
  { name: "Charities & Educational Law", href: "/charity-education-law/" },
  { name: "Commissioner for Oaths", href: "/commissioner-for-oaths/" },
  { name: "News & Blog", href: "/blog/" },
  { name: "Contact Us", href: "/contact" },
];
---

<header class="top-0 left-0 w-full z-50">
  <div class="flex justify-between items-center px-6 py-4">
    <button id="menuBtn" class="text-3xl">
      ☰
    </button>


<a
  href="/contact"
  class="hidden md:inline-block bg-[rgb(11,131,142)] text-white px-6 py-3 rounded-full"
>
  Contact Us ↗
</a>


  </div>
</header>

<div id="overlay" class="fixed inset-0 bg-black/40 hidden z-[999]">
  <div class="absolute left-0 top-0 h-full w-[320px] bg-white p-6 overflow-y-auto">


<div class="flex justify-between items-center mb-6">
  <h3 class="text-xl font-semibold">Menu</h3>

  <button id="closeBtn" class="text-2xl">
    ✕
  </button>
</div>

<div class="flex flex-col gap-4">
  {
    menuLinks.map((link) => (
      <a
        href={link.href}
        class="border-b border-gray-200 pb-3 hover:text-[rgb(11,131,142)] transition-colors"
      >
        {link.name}
      </a>
    ))
  }
</div>


  </div>
</div>

<script is:inline>
  const menuBtn = document.getElementById("menuBtn");
  const overlay = document.getElementById("overlay");
  const closeBtn = document.getElementById("closeBtn");

  menuBtn?.addEventListener("click", () => {
    overlay.classList.remove("hidden");
  });

  closeBtn?.addEventListener("click", () => {
    overlay.classList.add("hidden");
  });

  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) {
      overlay.classList.add("hidden");
    }
  });
</script>
