---

import matter from "gray-matter";

const postFiles = import.meta.glob(
"/hugo-blog/content/posts/*.md",
{
query: "?raw",
import: "default",
eager: true,
}
);

const blogs = Object.entries(postFiles).map(([filePath, rawContent]) => {
const { data } = matter(rawContent as string);

return {
title: data.title || "Untitled Post",
slug: filePath.split("/").pop()?.replace(".md", ""),
};
});
---

<header class="top-0 left-0 w-full z-50">
  <div class="flex justify-between items-center px-6 py-4">
    <button id="menuBtn" class="text-3xl">
      ☰
    </button>


<a
  href="/contact"
  class="hidden md:inline-block bg-[rgb(11,131,142)] text-white px-6 py-3 rounded-full"
>
  Contact Us ↗
</a>


  </div>
</header>

<div id="overlay" class="fixed inset-0 bg-black/40 hidden z-[999]">
  <div class="absolute left-0 top-0 h-full w-[320px] bg-white p-6 overflow-y-auto">


<div class="flex justify-between items-center mb-6">
  <h3 class="text-xl font-semibold">Blogs</h3>

  <button id="closeBtn" class="text-2xl">
    ✕
  </button>
</div>

<div class="flex flex-col gap-4">
  {
    blogs.map((blog, index) => (
      <a
        href={`/blog/${blog.slug}`}
        class="border-b border-gray-200 pb-3 hover:text-[rgb(11,131,142)] transition-colors"
      >
        {index + 1}. {blog.title}
      </a>
    ))
  }
</div>


  </div>
</div>

<script is:inline>
  const menuBtn = document.getElementById("menuBtn");
  const overlay = document.getElementById("overlay");
  const closeBtn = document.getElementById("closeBtn");

  menuBtn?.addEventListener("click", () => {
    overlay.classList.remove("hidden");
  });

  closeBtn?.addEventListener("click", () => {
    overlay.classList.add("hidden");
  });

  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) {
      overlay.classList.add("hidden");
    }
  });
</script>
