+  keywords="dispute resolution solicitor ireland, ADR solicitor limerick, mediation solicitor, commercial dispute solicitor, workplace conflict solicitor limerick"
 >
   <main class="w-full min-h-screen bg-white">
 
diff --git a/src/pages/index.astro b/src/pages/index.astro
index 6db6d89..78acf7b 100644
--- a/src/pages/index.astro
+++ b/src/pages/index.astro
@@ -88,7 +88,11 @@ const services = [
 ];
