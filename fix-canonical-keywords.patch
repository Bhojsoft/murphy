   title="Redundancy Solicitors Limerick | Martina Murphy Solicitors"
   description="Facing redundancy in Ireland? Our employment solicitors review severance agreements, verify redundancy payments, and challenge unfair selection processes."
+  keywords="redundancy solicitor limerick, redundancy pay ireland, unfair redundancy solicitor, employment law limerick, severance agreement solicitor"
 >
     <main class="w-full min-h-screen bg-white">
         <!-- HERO SECTION -->
